{
  "defaultProvider": "deepseek",
  "defaultModel": "deepseek-v4-pro",
  "defaultThinkingLevel": "xhigh",
  "enabledModels": [
    "deepseek-*",
    "mimo-*",
    "claude-*"
  ],
  "quietStartup": true,
  "theme": "dark",
  "enableInstallTelemetry": false,
  "compaction": {
    "enabled": true,
    "reserveTokens": 16384,
    "keepRecentTokens": 20000
  },
  "retry": {
    "enabled": true,
    "maxRetries": 3
  },
  "warnings": {
    "anthropicExtraUsage": true
  }
}
